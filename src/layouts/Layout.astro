---
import { ViewTransitions } from 'astro:transitions';
import { siteConfig } from '../site.config';

const { title = siteConfig.title } = Astro.props;
const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ViewTransitions />
    <style>
      html {
        scroll-behavior: smooth;
      }

      :root {
        color-scheme: light dark;

        /* Core tokens */
        --font-sans: system-ui, -apple-system, BlinkMacSystemFont, 'SF Pro Text',
          'Segoe UI', sans-serif;
        --radius-lg: 16px;
        --radius-md: 999px;
        --shadow-soft: 0 18px 45px rgba(15, 23, 42, 0.1);
        --transition-base: 200ms cubic-bezier(0.4, 0, 0.2, 1);

        /* Light theme */
        --bg-page: radial-gradient(
          ellipse at top left,
          #eef2ff 0%,
          #f9fafb 40%,
          #ffffff 100%
        );
        --bg-surface: #ffffff;
        --bg-elevated: #ffffff;
        --bg-soft: #f3f4ff;
        --text-main: #0f172a;
        --text-muted: #6b7280;
        --border-subtle: rgba(148, 163, 184, 0.3);
        --accent: #2563eb;
        --accent-soft: rgba(37, 99, 235, 0.06);
        --glow-accent: rgba(37, 99, 235, 0.08);
        --chip-bg: rgba(15, 23, 42, 0.04);
        --card-gradient: radial-gradient(
          circle at top left,
          rgba(219, 234, 254, 0.4),
          var(--bg-soft)
        );
        --header-bg: rgba(255, 255, 255, 0.82);
      }

      :root[data-theme='dark'] {
        color-scheme: dark;
        --bg-page: radial-gradient(
          ellipse at top left,
          #0f172a 0%,
          #060c1a 40%,
          #020617 100%
        );
        --bg-surface: #020617;
        --bg-elevated: #0f172a;
        --bg-soft: #0c1425;
        --text-main: #e2e8f0;
        --text-muted: #94a3b8;
        --border-subtle: rgba(148, 163, 184, 0.15);
        --accent: #60a5fa;
        --accent-soft: rgba(96, 165, 250, 0.1);
        --glow-accent: rgba(96, 165, 250, 0.06);
        --chip-bg: rgba(148, 163, 184, 0.08);
        --card-gradient: radial-gradient(
          circle at top left,
          rgba(96, 165, 250, 0.06),
          var(--bg-soft)
        );
        --header-bg: rgba(2, 6, 23, 0.82);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-sans);
        background: var(--bg-page);
        color: var(--text-main);
        display: flex;
        justify-content: center;
        padding: 3rem 1.5rem;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .shell {
        width: 100%;
        max-width: 920px;
        background: var(--bg-surface);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
        border: 1px solid var(--border-subtle);
        overflow: hidden;
        animation: shellFadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
      }

      @keyframes shellFadeIn {
        from {
          opacity: 0;
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      header {
        padding: 1.1rem 1.75rem;
        border-bottom: 1px solid var(--border-subtle);
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: var(--header-bg);
      }

      .header-left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 0.65rem;
      }

      .logo-dot {
        width: 14px;
        height: 14px;
        border-radius: var(--radius-md);
        background: radial-gradient(circle at 30% 0, #93c5fd, #2563eb);
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.18);
        transition: box-shadow var(--transition-base), transform var(--transition-base);
      }

      .home-link:hover .logo-dot {
        box-shadow: 0 0 0 6px rgba(37, 99, 235, 0.25);
        transform: scale(1.1);
      }

      .brand-title {
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .home-link {
        text-decoration: none;
        color: inherit;
      }

      nav {
        display: flex;
        gap: 0.25rem;
      }

      .nav-link {
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.3rem 0.65rem;
        border-radius: 0.5rem;
        transition: color var(--transition-base), background var(--transition-base);
      }

      .nav-link:hover {
        color: var(--accent);
        background: var(--accent-soft);
        text-decoration: none;
      }

      .theme-toggle {
        border-radius: 999px;
        border: 1px solid var(--border-subtle);
        background: var(--chip-bg);
        color: var(--text-muted);
        padding: 0.35rem 0.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.78rem;
        cursor: pointer;
        transition: background var(--transition-base), border-color var(--transition-base),
          color var(--transition-base), transform 150ms ease;
      }

      .theme-toggle:hover {
        transform: translateY(-1px);
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
      }

      .theme-toggle:active {
        transform: translateY(0) scale(0.97);
      }

      .theme-toggle-icon {
        font-size: 0.95rem;
        display: inline-block;
        transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      .theme-toggle-icon.is-rotating {
        transform: rotate(360deg);
      }

      main {
        padding: 1.8rem 1.75rem 2.1rem;
        animation: contentFadeIn 0.4s ease 0.15s both;
      }

      @keyframes contentFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      footer {
        border-top: 1px solid var(--border-subtle);
        padding: 1.25rem 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.78rem;
        color: var(--text-muted);
      }

      .footer-copy {
        margin: 0;
      }

      .footer-nav {
        display: flex;
        gap: 1rem;
      }

      .footer-nav a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color var(--transition-base);
      }

      .footer-nav a:hover {
        color: var(--accent);
      }

      @media (min-width: 768px) {
        header {
          padding: 1.25rem 2rem;
        }

        main {
          padding: 2.1rem 2.25rem 2.4rem;
        }

        footer {
          padding: 1.25rem 2rem;
        }
      }

      @media (max-width: 520px) {
        .brand-title {
          display: none;
        }

        .header-left {
          gap: 0.75rem;
        }
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color var(--transition-base);
      }

      a:hover {
        text-decoration: underline;
        text-underline-offset: 0.16em;
        text-decoration-thickness: 1px;
      }
    </style>

    <script>
      (function () {
        const storageKey = 'markdown-blog-theme';
        const root = document.documentElement;

        const getPreferred = () => {
          if (typeof window === 'undefined') return 'light';
          const stored = window.localStorage.getItem(storageKey);
          if (stored === 'light' || stored === 'dark') return stored;
          return window.matchMedia &&
            window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        };

        const applyTheme = (theme) => {
          root.dataset.theme = theme;
        };

        applyTheme(getPreferred());

        const updateIcon = () => {
          const icon = document.querySelector('[data-theme-icon]');
          if (!icon) return;
          icon.textContent = root.dataset.theme === 'dark' ? '☀' : '☾';
        };

        // Handle both initial load and View Transitions navigation
        const setup = () => {
          applyTheme(getPreferred());
          updateIcon();

          const btn = document.querySelector('[data-theme-toggle]');
          if (!btn || btn.dataset.bound) return;
          btn.dataset.bound = 'true';

          btn.addEventListener('click', () => {
            const icon = btn.querySelector('[data-theme-icon]');
            if (icon) {
              icon.classList.add('is-rotating');
              setTimeout(() => icon.classList.remove('is-rotating'), 500);
            }
            const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            applyTheme(next);
            window.localStorage.setItem(storageKey, next);
            updateIcon();
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setup);
        } else {
          setup();
        }
        document.addEventListener('astro:after-swap', setup);
      })();
    </script>
  </head>
  <body>
    <div class="shell">
      <header>
        <div class="header-left">
          <a href="/markdown-blog/" class="home-link">
            <div class="brand">
              <div class="logo-dot" />
              <div class="brand-title">{siteConfig.name}</div>
            </div>
          </a>
          <nav>
            <a href="/markdown-blog/" class="nav-link">{siteConfig.nav.blogLabel}</a>
            <a href="/markdown-blog/about/" class="nav-link">{siteConfig.nav.aboutLabel}</a>
          </nav>
        </div>
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label="Toggle light and dark theme"
        >
          <span class="theme-toggle-icon" data-theme-icon>☾</span>
          <span>Theme</span>
        </button>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <p class="footer-copy">&copy; {currentYear} {siteConfig.footer.copyright}</p>
        <div class="footer-nav">
          <a href="/markdown-blog/">{siteConfig.nav.blogLabel}</a>
          <a href="/markdown-blog/about/">{siteConfig.nav.aboutLabel}</a>
        </div>
      </footer>
    </div>
  </body>
</html>
