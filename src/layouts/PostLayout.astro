---
import Layout from './Layout.astro';
import { siteConfig } from '../site.config';

const { frontmatter = {} } = Astro.props as { frontmatter?: Record<string, any> };
const {
  title = 'Untitled post',
  description,
  pubDate,
  author = siteConfig.author.name,
  readingTime,
} = frontmatter;

const published =
  pubDate instanceof Date ? pubDate : pubDate ? new Date(pubDate) : null;
const minutes =
  typeof readingTime === 'number'
    ? readingTime
    : readingTime
    ? Number(readingTime)
    : null;
---

<Layout title={title}>
  <div class="progress-bar" id="progress-bar" aria-hidden="true" />

  <article class="post">
    <a href="/markdown-blog/" class="back-link">← {siteConfig.nav.blogLabel}</a>

    <header class="post-header">
      <h1>{title}</h1>
      <p class="meta">
        {published && (
          <time datetime={published.toISOString()}>
            {published.toLocaleDateString(undefined, {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        )}
        {author && (
          <span> · {author}</span>
        )}
        {minutes && minutes > 0 && (
          <span> · {minutes} min read</span>
        )}
      </p>
      {description && <p class="description">{description}</p>}
    </header>

    <div class="post-body">
      <slot />
    </div>
  </article>

  <script>
    function setupProgress() {
      const bar = document.getElementById('progress-bar');
      if (!bar) return;
      const update = () => {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = h > 0 ? `${Math.min((window.scrollY / h) * 100, 100)}%` : '0%';
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupProgress);
    } else {
      setupProgress();
    }
    document.addEventListener('astro:after-swap', setupProgress);
  </script>

  <style>
    .progress-bar {
      position: fixed;
      top: 0;
      left: 0;
      height: 2px;
      width: 0%;
      background: var(--accent);
      z-index: 200;
      transition: width 0.08s linear;
    }

    .post {
      max-width: var(--max-width);
    }

    .back-link {
      display: inline-block;
      font-size: 0.875rem;
      color: var(--text-muted);
      text-decoration: none;
      margin-bottom: 2rem;
      transition: color var(--transition);
    }

    .back-link:hover {
      color: var(--text);
      text-decoration: none;
    }

    .post-header {
      margin-bottom: 2.5rem;
    }

    h1 {
      font-family: var(--font-serif);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin: 0 0 0.75rem;
    }

    .meta {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin: 0;
    }

    .description {
      margin: 1rem 0 0;
      font-size: 1.0625rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* Post body */
    .post-body {
      font-size: 1.125rem;
      line-height: 1.8;
      color: var(--text);
    }

    .post-body :global(p) {
      margin: 0 0 1.5rem;
    }

    .post-body :global(p:last-child) {
      margin-bottom: 0;
    }

    .post-body :global(h2) {
      font-family: var(--font-serif);
      font-size: 1.5rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin: 3rem 0 1rem;
    }

    .post-body :global(h3) {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 600;
      margin: 2.5rem 0 0.75rem;
    }

    .post-body :global(ul),
    .post-body :global(ol) {
      margin: 0 0 1.5rem;
      padding-left: 1.25rem;
    }

    .post-body :global(li + li) {
      margin-top: 0.375rem;
    }

    .post-body :global(code) {
      font-family: var(--font-mono);
      font-size: 0.875em;
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      background: var(--code-bg);
    }

    .post-body :global(pre) {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      margin: 1.5rem 0;
      padding: 1.25rem 1.5rem;
      border-radius: 0.5rem;
      background: var(--code-block-bg);
      color: var(--code-block-text);
      overflow-x: auto;
      line-height: 1.6;
    }

    .post-body :global(pre code) {
      background: none;
      padding: 0;
      font-size: inherit;
    }

    .post-body :global(blockquote) {
      margin: 1.5rem 0;
      padding: 0 0 0 1.25rem;
      border-left: 2px solid var(--border);
      font-style: italic;
      color: var(--text-muted);
    }

    .post-body :global(blockquote p) {
      margin: 0;
    }

    .post-body :global(a) {
      color: var(--accent);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.15em;
    }

    .post-body :global(hr) {
      border: none;
      height: 1px;
      background: var(--border);
      margin: 2.5rem 0;
    }

    .post-body :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 0.5rem;
      margin: 1.5rem 0;
    }
  </style>
</Layout>
