---
import Layout from './Layout.astro';

const {
  title = 'Untitled post',
  description,
  pubDate,
  author = 'Lenora Porter',
  readingTime,
} = Astro.props;

const published =
  pubDate instanceof Date ? pubDate : pubDate ? new Date(pubDate) : null;
const minutes =
  typeof readingTime === 'number'
    ? readingTime
    : readingTime
    ? Number(readingTime)
    : null;
---

<Layout title={title}>
  <article class="post">
    <header class="post-header">
      <p class="eyebrow">Article</p>
      <h1>{title}</h1>

      <div class="meta-row">
        {published && (
          <p class="meta-chip">
            <span>Published</span>
            <time datetime={published.toISOString()}>
              {published.toLocaleDateString(undefined, {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          </p>
        )}

        {author && (
          <p class="meta-chip">
            <span>Author</span>
            <a href="/markdown-blog/about/" class="author-link">
              <strong>{author}</strong>
            </a>
          </p>
        )}

        {minutes && minutes > 0 && (
          <p class="meta-chip">
            <span>Reading time</span>
            <strong>
              {minutes} min{minutes > 1 ? 's' : ''}
            </strong>
          </p>
        )}
      </div>

      {description && <p class="description">{description}</p>}
    </header>

    <div class="post-body">
      <slot />
    </div>
  </article>

  <style>
    .post {
      max-width: 720px;
      margin: 0 auto;
    }

    .post-header {
      margin-bottom: 1.8rem;
    }

    .eyebrow {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--text-muted);
      margin: 0 0 0.4rem;
    }

    h1 {
      margin: 0 0 0.6rem;
      font-size: clamp(2rem, 3vw, 2.5rem);
      letter-spacing: -0.04em;
    }

    .description {
      margin: 1rem 0 0;
      color: var(--text-muted);
      font-size: 0.98rem;
      max-width: 36rem;
    }

    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 0.4rem;
    }

    .meta-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      border-radius: 999px;
      border: 1px solid var(--border-subtle);
      padding: 0.25rem 0.75rem;
      font-size: 0.78rem;
      color: var(--text-muted);
      background: var(--chip-bg);
    }

    .meta-chip span {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.7rem;
    }

    .meta-chip time,
    .meta-chip strong,
    .meta-chip .author-link {
      font-weight: 500;
      color: var(--text-main);
    }

    .author-link {
      text-decoration: none;
    }

    .author-link:hover {
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.16em;
    }

    .post-body {
      padding-top: 0.75rem;
      border-top: 1px solid var(--border-subtle);
      font-size: 0.98rem;
      line-height: 1.7;
      color: var(--text-main);
    }

    .post-body p {
      margin: 0 0 1rem;
    }

    .post-body p:last-child {
      margin-bottom: 0;
    }

    .post-body h2,
    .post-body h3 {
      margin-top: 1.8rem;
      margin-bottom: 0.6rem;
      letter-spacing: -0.02em;
    }

    .post-body h2 {
      font-size: 1.4rem;
    }

    .post-body h3 {
      font-size: 1.2rem;
    }

    .post-body ul,
    .post-body ol {
      margin: 0 0 1rem 1.25rem;
      padding: 0;
    }

    .post-body li + li {
      margin-top: 0.25rem;
    }

    .post-body code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
        'Liberation Mono', 'Courier New', monospace;
      font-size: 0.85rem;
      padding: 0.1rem 0.32rem;
      border-radius: 0.3rem;
      background: var(--accent-soft);
    }

    .post-body pre {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
        'Liberation Mono', 'Courier New', monospace;
      font-size: 0.85rem;
      margin: 1.25rem 0;
      padding: 0.9rem 1rem;
      border-radius: 0.7rem;
      background: #020617;
      color: #e5e7eb;
      overflow-x: auto;
    }

    :root[data-theme='dark'] .post-body pre {
      background: #020617;
    }

    .post-body a {
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.16em;
    }
  </style>
</Layout>

