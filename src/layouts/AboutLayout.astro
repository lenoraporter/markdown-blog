---
import Layout from './Layout.astro';
import { siteConfig } from '../site.config';

const { frontmatter = {} } = Astro.props as { frontmatter?: Record<string, any> };
const {
  title = `About ${siteConfig.author.name}`,
  greeting = `Hi, I'm ${siteConfig.author.name.split(' ')[0]}.`,
  lede,
} = frontmatter;
---

<Layout title={title}>
  <section class="about">
    <header class="about-header">
      <h1>{greeting}</h1>
      {lede && <p class="lede">{lede}</p>}
    </header>

    <div class="about-body">
      <slot />
    </div>
  </section>

  <style>
    .about {
      max-width: var(--max-width);
    }

    .about-header {
      margin-bottom: 2.5rem;
    }

    h1 {
      font-family: var(--font-sans);
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin: 0 0 0.75rem;
    }

    .lede {
      margin: 0;
      font-size: 1rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .about-body {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--text);
    }

    .about-body :global(h2) {
      font-family: var(--font-sans);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin: 2.5rem 0 1rem;
    }

    .about-body :global(h2:first-child) {
      margin-top: 0;
    }

    .about-body :global(p) {
      margin: 0 0 1.25rem;
    }

    .about-body :global(p:last-child) {
      margin-bottom: 0;
    }

    .about-body :global(ul) {
      margin: 0 0 1.25rem;
      padding-left: 1.25rem;
    }

    .about-body :global(li + li) {
      margin-top: 0.375rem;
    }

    .about-body :global(a) {
      color: var(--accent);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.15em;
    }
  </style>
</Layout>
