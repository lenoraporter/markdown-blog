---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Lenora Porter">
  <section class="about">
    <header class="about-header">
      <p class="eyebrow">About</p>
      <h1>Hi, I&apos;m Lenora.</h1>
      <p class="lede">
        This is a markdown-first blog where I share notes, career stories, and
        experiments in public. Every article starts as a simple <code>.md</code>
        file committed to GitHub.
      </p>
    </header>

    <div class="about-grid">
      <div class="card">
        <h2>What you&apos;ll find here</h2>
        <ul>
          <li>Deep dives into software engineering and developer experience</li>
          <li>Notes on learning, teaching, and mentoring in tech</li>
          <li>Behind-the-scenes on side projects and experiments</li>
        </ul>
      </div>

      <div class="card secondary">
        <h2>About me</h2>
        <p>
          I&apos;m a developer and educator who likes building simple tools that
          feel good to use. This blog is designed so writing is as easy as
          editing a markdown file and pushing to GitHub.
        </p>
        <p>
          Want to say hi or share feedback? Drop a link, question, or idea in
          your own fork of this repo, or reach out on your favorite platform.
        </p>
      </div>
    </div>
  </section>

  <style>
    .about {
      max-width: 780px;
      margin: 0 auto;
    }

    .about-header {
      margin-bottom: 2rem;
    }

    .eyebrow {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--text-muted);
      margin: 0 0 0.4rem;
    }

    h1 {
      margin: 0 0 0.6rem;
      font-size: clamp(2rem, 3vw, 2.4rem);
      letter-spacing: -0.04em;
    }

    .lede {
      margin: 0;
      color: var(--text-muted);
      font-size: 0.98rem;
      max-width: 40rem;
    }

    .about-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      gap: 1.3rem;
    }

    @media (max-width: 720px) {
      .about-grid {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .card {
      border-radius: 1rem;
      border: 1px solid var(--border-subtle);
      padding: 1.25rem 1.3rem;
      background: radial-gradient(
        circle at top left,
        rgba(219, 234, 254, 0.38),
        var(--bg-soft)
      );
      box-shadow: 0 10px 26px rgba(15, 23, 42, 0.08);
    }

    .card.secondary {
      background: radial-gradient(
        circle at top left,
        rgba(190, 242, 255, 0.25),
        var(--bg-soft)
      );
    }

    .card h2 {
      margin: 0 0 0.75rem;
      font-size: 1.1rem;
      letter-spacing: -0.02em;
    }

    .card p {
      margin: 0 0 0.75rem;
      font-size: 0.96rem;
      color: var(--text-main);
    }

    .card p:last-child {
      margin-bottom: 0;
    }

    .card ul {
      margin: 0;
      padding-left: 1.1rem;
      font-size: 0.95rem;
      color: var(--text-main);
    }

    .card li + li {
      margin-top: 0.3rem;
    }
  </style>
</Layout>

