---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../site.config';

const postImportResult = import.meta.glob('./posts/*.md', { eager: true });

type PostModule = {
  frontmatter: {
    title: string;
    description?: string;
    pubDate?: string;
    author?: string;
    readingTime?: number;
  };
  url: string;
};

const posts = Object.values(postImportResult as Record<string, PostModule>)
  .map((post) => ({
    title: post.frontmatter.title,
    description: post.frontmatter.description ?? '',
    pubDate: post.frontmatter.pubDate
      ? new Date(post.frontmatter.pubDate)
      : null,
    author: post.frontmatter.author ?? siteConfig.author.name,
    readingTime: post.frontmatter.readingTime ?? null,
    url: post.url,
  }))
  .sort((a, b) => {
    if (!a.pubDate || !b.pubDate) return 0;
    return b.pubDate.getTime() - a.pubDate.getTime();
  });
---

<Layout title={siteConfig.title}>
  <section class="hero">
    {siteConfig.heroImage && (
      <img
        src={`/markdown-blog${siteConfig.heroImage}`}
        alt={siteConfig.author.name}
        class="hero-image"
        width="120"
        height="120"
      />
    )}
    <h1 class="hero-title">{siteConfig.heroTitle}</h1>
    <p class="hero-desc">
      {siteConfig.tagline}{' '}
      <a href="/markdown-blog/about/" class="about-link">Learn more about me.</a>
    </p>
  </section>

  {posts.length === 0 ? (
    <p class="empty">
      No posts yet. Add your first markdown file in <code>src/pages/posts/</code>.
    </p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={post.url} class="post-link">
            <div class="post-meta">
              {post.pubDate && (
                <time datetime={post.pubDate.toISOString()}>
                  {post.pubDate.toLocaleDateString(undefined, {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              )}
              {post.readingTime && (
                <span> · {post.readingTime} min read</span>
              )}
            </div>
            <h2 class="post-title">{post.title}</h2>
            {post.description && (
              <p class="post-desc">{post.description}</p>
            )}
            <span class="post-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  )}

  <style>
    .hero {
      max-width: var(--max-width);
      margin-bottom: 3rem;
    }

    .hero-image {
      width: 120px;
      height: 120px;
      border-radius: 12px;
      object-fit: cover;
      margin-bottom: 1.5rem;
    }

    .hero-title {
      font-family: var(--font-serif);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin: 0 0 0.75rem;
    }

    .hero-desc {
      font-size: 1.125rem;
      color: var(--text-muted);
      line-height: 1.6;
      margin: 0;
      max-width: 540px;
    }

    .about-link {
      color: var(--accent) !important;
      text-decoration: underline !important;
      text-decoration-thickness: 1px;
      text-underline-offset: 0.15em;
    }

    .empty {
      color: var(--text-muted);
      font-size: 0.9375rem;
    }

    .empty code {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      background: var(--code-bg);
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
    }

    .post-list {
      list-style: none;
      margin: 0;
      padding: 0;
      max-width: var(--max-width);
    }

    .post-list li {
      border-top: 1px solid var(--border);
    }

    .post-list li:last-child {
      border-bottom: 1px solid var(--border);
    }

    .post-link {
      display: block;
      padding: 1.5rem 0;
      padding-right: 2rem;
      text-decoration: none !important;
      color: inherit !important;
      position: relative;
    }

    .post-link:hover {
      color: inherit !important;
    }

    .post-link:hover .post-title {
      color: var(--accent);
    }

    .post-link:hover .post-arrow {
      opacity: 1;
      transform: translateX(0);
    }

    .post-meta {
      font-size: 0.8125rem;
      color: var(--text-muted);
      margin-bottom: 0.375rem;
    }

    .post-title {
      font-family: var(--font-serif);
      font-size: 1.375rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin: 0 0 0.25rem;
      line-height: 1.3;
      transition: color var(--transition);
    }

    .post-desc {
      font-size: 0.9375rem;
      color: var(--text-muted);
      margin: 0;
      line-height: 1.5;
    }

    .post-arrow {
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateX(-4px);
      color: var(--accent);
      opacity: 0;
      transition: opacity var(--transition), transform var(--transition);
      font-size: 1.125rem;
    }
  </style>
</Layout>
