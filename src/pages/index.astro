---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../site.config';

const postImportResult = import.meta.glob('./posts/*.md', { eager: true });

type PostModule = {
  frontmatter: {
    title: string;
    description?: string;
    pubDate?: string;
    author?: string;
    readingTime?: number;
  };
  url: string;
};

const posts = Object.values(postImportResult as Record<string, PostModule>)
  .map((post) => ({
    title: post.frontmatter.title,
    description: post.frontmatter.description ?? '',
    pubDate: post.frontmatter.pubDate
      ? new Date(post.frontmatter.pubDate)
      : null,
    author: post.frontmatter.author ?? siteConfig.author.name,
    readingTime: post.frontmatter.readingTime ?? null,
    url: post.url,
  }))
  .sort((a, b) => {
    if (!a.pubDate || !b.pubDate) return 0;
    return b.pubDate.getTime() - a.pubDate.getTime();
  });
---

<Layout title={siteConfig.title}>
  <section class="hero">
    <p class="hero-eyebrow">Welcome to</p>
    <h1 class="hero-title">
      <span class="hero-gradient">{siteConfig.name}</span>
    </h1>
    <p class="hero-lead">{siteConfig.tagline}</p>
  </section>

  {posts.length === 0 ? (
    <p class="empty">
      No posts yet. Add your first markdown file in
      <code>src/pages/posts/</code>.
    </p>
  ) : (
    <section class="posts-section">
      <h2 class="posts-heading">Recent posts</h2>
      <ul class="post-list">
        {posts.map((post, i) => (
          <li style={`--i: ${i}`}>
            <a href={post.url} class="post-card-link">
              <div class="post-card-meta">
                <span class="post-avatar" aria-hidden="true">
                  {post.author.charAt(0)}
                </span>
                <span class="post-author">{post.author}</span>
                {post.pubDate && (
                  <span class="post-date">
                    <span class="meta-dot" aria-hidden="true" />
                    <time datetime={post.pubDate.toISOString()}>
                      {post.pubDate.toLocaleDateString(undefined, {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                      })}
                    </time>
                  </span>
                )}
              </div>
              <h3 class="post-card-title">{post.title}</h3>
              {post.description && (
                <p class="post-card-desc">{post.description}</p>
              )}
              <div class="post-card-footer">
                {post.readingTime && (
                  <span class="reading-badge">
                    {post.readingTime} min read
                  </span>
                )}
                <span class="read-more">Read article →</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <style>
    /* Hero */
    .hero {
      margin-bottom: 2.5rem;
    }

    .hero-eyebrow {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--text-muted);
      margin: 0 0 0.3rem;
    }

    .hero-title {
      font-size: clamp(2.2rem, 4vw, 3rem);
      margin: 0 0 0.6rem;
      letter-spacing: -0.04em;
      line-height: 1.1;
    }

    .hero-gradient {
      background: linear-gradient(
        135deg,
        var(--accent),
        #7c3aed,
        var(--accent),
        #06b6d4
      );
      background-size: 300% 300%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: gradientShift 6s ease infinite;
    }

    @keyframes gradientShift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }

    .hero-lead {
      margin: 0;
      color: var(--text-muted);
      font-size: 1rem;
      max-width: 34rem;
      line-height: 1.6;
    }

    /* Posts section */
    .posts-section {
      margin-top: 0.5rem;
    }

    .posts-heading {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--text-muted);
      font-weight: 600;
      margin: 0 0 1rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border-subtle);
    }

    .empty {
      margin-top: 1rem;
      color: var(--text-muted);
      font-size: 0.95rem;
    }

    code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
        'Liberation Mono', 'Courier New', monospace;
      background: var(--accent-soft);
      padding: 0.1rem 0.35rem;
      border-radius: 0.35rem;
      font-size: 0.86rem;
      margin-left: 0.25rem;
    }

    /* Post list */
    .post-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .post-list li {
      animation: fadeUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
      animation-delay: calc(var(--i) * 80ms);
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .post-card-link {
      display: block;
      padding: 1.25rem 1.35rem;
      border-radius: 1rem;
      border: 1px solid var(--border-subtle);
      background: var(--bg-elevated);
      text-decoration: none;
      color: inherit;
      transition:
        transform 200ms cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 200ms cubic-bezier(0.4, 0, 0.2, 1),
        border-color 200ms cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
    }

    .post-card-link:hover {
      transform: translateY(-3px);
      box-shadow:
        0 12px 32px rgba(15, 23, 42, 0.1),
        0 0 0 1px var(--glow-accent);
      border-color: var(--accent);
      text-decoration: none;
    }

    /* Card meta row */
    .post-card-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.6rem;
      font-size: 0.82rem;
      color: var(--text-muted);
    }

    .post-avatar {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #7c3aed);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .post-author {
      font-weight: 500;
      color: var(--text-main);
    }

    .post-date {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .meta-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--text-muted);
      opacity: 0.6;
    }

    /* Card content */
    .post-card-title {
      margin: 0 0 0.35rem;
      font-size: 1.2rem;
      letter-spacing: -0.02em;
      line-height: 1.3;
      transition: color 200ms ease;
    }

    .post-card-link:hover .post-card-title {
      color: var(--accent);
    }

    .post-card-desc {
      margin: 0;
      font-size: 0.92rem;
      color: var(--text-muted);
      line-height: 1.5;
    }

    /* Card footer */
    .post-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 0.75rem;
      font-size: 0.78rem;
    }

    .reading-badge {
      color: var(--text-muted);
      background: var(--chip-bg);
      padding: 0.2rem 0.55rem;
      border-radius: 999px;
      border: 1px solid var(--border-subtle);
    }

    .read-more {
      color: var(--accent);
      font-weight: 500;
      opacity: 0;
      transform: translateX(-6px);
      transition:
        opacity 200ms ease,
        transform 200ms ease;
    }

    .post-card-link:hover .read-more {
      opacity: 1;
      transform: translateX(0);
    }
  </style>
</Layout>
